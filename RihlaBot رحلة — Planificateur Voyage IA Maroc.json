      "id": "dd5bcf71-d247-4158-b6d2-69790f16dc62",
      "name": "Set Input",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [208, 0]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer VOTRE_CLE_GROQ_ICI"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Tu es un assistant voyage Maroc. Extrait et retourne UNIQUEMENT ce JSON sans backticks ni texte autour : {\\\"destination\\\":\\\"\\\",\\\"dates\\\":\\\"\\\",\\\"budget_dh\\\":\\\"\\\",\\\"style\\\":\\\"\\\",\\\"voyageurs\\\":\\\"\\\",\\\"nb_nuits\\\":\\\"\\\",\\\"trip_type\\\":\\\"\\\",\\\"langue\\\":\\\"fr\\\"}\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Données reçues : destination={{ $json.destination }}, dates={{ $json.dates }}, budget={{ $json.budget_dh }}, style={{ $json.style }}, voyageurs={{ $json.voyageurs }}, nb_nuits={{ $json.nb_nuits }}, trip_type={{ $json.trip_type }}, langue={{ $json.langue }}\"\n    }\n  ],\n  \"temperature\": 0\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "2b6c2843-4026-41d6-bae7-31438d4d5eb0",
      "name": "OpenAI Parsing",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [432, 0]
    },
    {
      "parameters": {
        "jsCode": "// Mode : Run Once for Each Item\n// Parsing robuste du JSON retourné par le LLM\nconst input = $input.item.json;\n\nlet raw = '';\ntry {\n  raw = input.choices[0].message.content || '{}';\n} catch(e) {\n  raw = JSON.stringify(input);\n}\n\nlet data = {};\ntry {\n  const cleaned = raw.replace(/```json?|```/g, '').trim();\n  data = JSON.parse(cleaned);\n} catch(e) {\n  data = {\n    destination: $('Set Input').item.json.destination || 'Marrakech',\n    dates: $('Set Input').item.json.dates || 'non précisé',\n    budget_dh: $('Set Input').item.json.budget_dh || '1000-3000 DH',\n    style: $('Set Input').item.json.style || 'Culturel',\n    voyageurs: $('Set Input').item.json.voyageurs || '2 personnes',\n    nb_nuits: $('Set Input').item.json.nb_nuits || '2 nuits',\n    trip_type: $('Set Input').item.json.trip_type || 'destination_unique',\n    langue: $('Set Input').item.json.langue || 'fr'\n  };\n}\n\nconst cleanVal = (v) => String(v || '').replace(/[^\\w\\s\\-àâäéèêëîïôùûüç,.:0-9]/gi, '').trim();\n\nreturn {\n  destination: cleanVal(data.destination) || cleanVal($('Set Input').item.json.destination) || 'Marrakech',\n  dates: data.dates || $('Set Input').item.json.dates || 'non précisé',\n  budget_dh: data.budget_dh || $('Set Input').item.json.budget_dh || '1000-3000 DH',\n  style: cleanVal(data.style) || cleanVal($('Set Input').item.json.style) || 'Culturel',\n  voyageurs: data.voyageurs || $('Set Input').item.json.voyageurs || '2 personnes',\n  nb_nuits: data.nb_nuits || $('Set Input').item.json.nb_nuits || '2 nuits',\n  trip_type: data.trip_type || $('Set Input').item.json.trip_type || 'destination_unique',\n  langue: data.langue || $('Set Input').item.json.langue || 'fr',\n  botpress_user_id: $('Set Input').item.json.botpress_user_id || ''\n};"
      },
      "id": "2b9ca2e0-6fbc-4a10-b548-f63c31ee01cd",
      "name": "Code Parse JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [656, 0]
    },
    {
      "parameters": {
        "url": "=https://api.openweathermap.org/data/2.5/forecast?q={{ $('Code Parse JSON').item.json.destination }},MA&appid=VOTRE_CLE_OPENWEATHER_ICI&units=metric&lang=fr&cnt=8",
        "options": {
          "timeout": 10000
        }
      },
      "id": "3962e858-f630-4dc6-b5c0-5c9c850c6ae6",
      "name": "Weather API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [864, 0]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "set-meteo",
              "name": "meteo_final",
              "value": "={{ (() => {\n  try {\n    const list = $json.list;\n    if (!list || list.length === 0) return 'Météo non disponible';\n    const item = list[0];\n    const temp = Math.round(item.main.temp);\n    const desc = item.weather[0].description;\n    const humidity = item.main.humidity;\n    return `${temp}°C, ${desc}, humidité ${humidity}%`;\n  } catch(e) {\n    return 'Météo non disponible';\n  }\n})() }}",
              "type": "string"
            },
            {
              "id": "pass-destination",
              "name": "destination",
              "value": "={{ $('Code Parse JSON').item.json.destination }}",
              "type": "string"
            },
