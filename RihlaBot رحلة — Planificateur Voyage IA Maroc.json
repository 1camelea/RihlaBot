        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Tu es RihlaBot, expert en tourisme marocain depuis 15 ans. Tu connais : prix en DH 2025, riads, CTM/Supratours/grand taxi, souks, tajine, harira, couscous, Ramadan, fêtes nationales.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Génère un itinéraire pour : {{ $json.destination }}, départ {{ $json.dates }}, {{ $json.nb_nuits }} de séjour, budget {{ $json.budget_dh }}, {{ $json.voyageurs }}, style {{ $json.style }}.\\n\\nMétéo prévue : {{ $json.meteo_final }}\\n\\nFormat OBLIGATOIRE pour chaque jour :\\nJour X — [Titre thématique]\\n🌅 Matin : activité (~XX DH)\\n☀️ Après-midi : activité (~XX DH)\\n🌙 Soir : restaurant (~XX DH/pers)\\n💡 Conseil : 1 astuce culturelle locale\\n\\nPrix en DH uniquement. Maximum 5 jours.\\nCommence par 'Marhaba ! 🌟'\\nRéponds en {{ $json.langue }}.\"\n    }\n  ],\n  \"temperature\": 0.7,\n  \"max_tokens\": 1500\n}",
        "options": {
          "timeout": 60000
        }
      },
