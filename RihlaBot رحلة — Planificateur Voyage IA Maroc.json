        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Tu es un assistant voyage Maroc. Extrait et retourne UNIQUEMENT ce JSON sans backticks ni texte autour : {\\\"destination\\\":\\\"\\\",\\\"dates\\\":\\\"\\\",\\\"budget_dh\\\":\\\"\\\",\\\"style\\\":\\\"\\\",\\\"voyageurs\\\":\\\"\\\",\\\"nb_nuits\\\":\\\"\\\",\\\"trip_type\\\":\\\"\\\",\\\"langue\\\":\\\"fr\\\"}\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Données reçues : destination=$('Set Meteo').destination.json.*, dates=$('Set Meteo').dates.json.*, budget=$('Set Meteo').budget_dh.json.*, style=$('Set Meteo').style.json.*, voyageurs=$('Set Meteo').voyageurs.json.*, nb_nuits=$('Set Meteo').nb_nuits.json.*, trip_type=$('Set Meteo').trip_type.json.*, langue=$('Set Meteo').langue.json.*\"\n    }\n  ],\n  \"temperature\": 0\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "2b6c2843-4026-41d6-bae7-31438d4d5eb0",
      "name": "OpenAI Parsing",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        432,
        0
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "n73JbwVzMuWYzwXv",
          "name": "Header Auth account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const input = $('Set Input').item.json;\n\nconst cleanVal = (v) => String(v || '')\n  .replace(/[^\\w\\s\\-àâäéèêëîïôùûüç,.:0-9]/gi, '')\n  .trim();\n\nconst cleanSimple = (v) => String(v || '').trim();\n\nreturn {\n  destination: cleanVal(input.destination) || cleanVal(input.ville1) || 'Marrakech',\n  dates: cleanSimple(input.dates) || cleanSimple(input.date_depart) || 'non précisé',\n  budget_dh: cleanSimple(input.budget_dh) || cleanSimple(input.budget) || '1000-3000 DH',\n  style: cleanVal(input.style) || 'Culturel',\n  voyageurs: cleanSimple(input.voyageurs) || cleanSimple(input.nb_voyageurs) || '2 personnes',\n  nb_nuits: cleanSimple(input.nb_nuits) || '2 nuits',\n  trip_type: cleanSimple(input.trip_type) || 'destination_unique',\n  langue: cleanSimple(input.langue) || 'fr',\n  botpress_user_id: cleanSimple(input.botpress_user_id) || ''\n};"
      },
      "id": "2b9ca2e0-6fbc-4a10-b548-f63c31ee01cd",
